version: "0.2"

# =====================================================================================
# VIRTUAL CONTEXT — COMPLETE REFERENCE CONFIGURATION
# =====================================================================================
# This file documents every configurable parameter with its default value.
# Copy to virtual-context.yaml and customize as needed.
#
# Quick start (local Ollama):
#   cp virtual-context.yaml.example virtual-context.yaml
#   virtual-context chat
#
# Proxy mode (enriches any LLM client):
#   virtual-context -c virtual-context.yaml proxy --upstream https://api.anthropic.com --port 5757

storage_root: ".virtualcontext"                     # base directory for all VC data
context_window: 120000                              # total token budget — match your model's limit
token_counter: "estimate"                           # "estimate" | "tiktoken" | "callable:module.path:func"

# =====================================================================================
# PAGING — virtual memory depth control
# =====================================================================================
# Lets the LLM manage its own context budget via expand/collapse tools.
# autonomous_models: model-name prefixes (case-insensitive startswith matching).
# Matching models get vc_expand_topic / vc_collapse_topic tools injected.
# Non-matching models run in supervised mode (VC pages silently).

paging:
  enabled: true
  auto_promote: true                                # auto-expand on strong retrieval match
  auto_evict: true                                  # auto-collapse coldest when over budget
  max_tool_loops: 10                                # max continuation rounds in tool loop
  autonomous_models:
    # Anthropic
    - claude-sonnet-4                               # claude-sonnet-4-5, claude-sonnet-4-6
    - claude-opus-4                                 # claude-opus-4-5, claude-opus-4-6
    - claude-3-5-sonnet                             # legacy claude-3-5-sonnet-*
    - claude-3.5-sonnet                             # legacy claude-3.5-sonnet-*
    - claude-3-7-sonnet                             # legacy claude-3-7-sonnet-*
    - claude-3.7-sonnet                             # legacy claude-3.7-sonnet-*
    - claude-3-opus                                 # legacy claude-3-opus-*
    # OpenAI
    - gpt-4o                                        # gpt-4o, gpt-4o-mini
    - gpt-4-turbo                                   # gpt-4-turbo
    - gpt-4.1                                       # gpt-4.1, gpt-4.1-mini, gpt-4.1-nano
    - gpt-5                                         # gpt-5, gpt-5-mini, gpt-5.2, gpt-5.4
    - o1                                            # o1
    - o3                                            # o3, o3-mini
    - o4-mini                                       # o4-mini
    # Google
    - gemini-2.5-pro                                # gemini-2.5-pro-*
    - gemini-2.5-flash                              # gemini-2.5-flash-*
    - gemini-3                                      # gemini-3-pro-*, gemini-3.1-pro-*
    - gemini-2.0-flash                              # gemini-2.0-flash-*

# =====================================================================================
# TAG GENERATOR — how conversation turns get semantic tags
# =====================================================================================
# Every user+assistant exchange is tagged with semantic labels (e.g. "database",
# "authentication"). Tags drive retrieval: when you mention "database" later,
# VC fetches stored summaries sharing that tag.
#
# type: "llm"     — LLM generates tags (best quality, requires provider)
# type: "keyword" — deterministic keyword/regex matching (no LLM needed)

tag_generator:
  type: "llm"
  provider: "ollama"                                # must match a key in providers section
  model: "qwen3:4b-instruct-2507-fp16"
  max_tags: 10                                      # upper bound on tags per exchange
  min_tags: 5                                       # lower bound — encourages richer tagging
  max_tokens: 8192                                  # LLM max_tokens for tagger calls
  prompt_mode: "compact"                            # "detailed" (full rules) or "compact" (minimal)
  context_lookback_pairs: 5                         # recent turn pairs fed as tagger context
  context_bleed_threshold: 0.1                      # embedding similarity gate (0 = disabled)
  disable_thinking: false                           # prepend /no_think for qwen3 models
  temporal_heuristic_enabled: true                  # regex-based temporal detection

  # temporal_patterns: regex patterns for temporal-query detection.
  # Defaults are built in (8 patterns). Set to [] to disable.
  # temporal_patterns: []

  # Tag splitting — automatic splitting of overly-broad tags
  tag_splitting:
    enabled: false
    frequency_threshold: 15                         # min absolute turn count to trigger
    frequency_pct_threshold: 0.15                   # min relative frequency
    max_splits_per_turn: 1                          # max tags to attempt per on_turn_complete

  # keyword_fallback: deterministic tagging when LLM is unavailable
  keyword_fallback:
    tag_keywords:
      legal:
        - court
        - filing
        - motion
        - attorney
        - legal
        - case
        - judge
      medical:
        - insulin
        - medication
        - doctor
        - lab
        - blood
        - glucose
      code:
        - function
        - bug
        - deploy
        - git
        - API
        - database
        - error
    tag_patterns:
      legal:
        - "\\bN\\.?J\\.?S\\.?A\\.?\\b"
        - "\\b\\d{2}-cv-\\d+"
      code:
        - "\\bdef \\w+\\("
        - "\\bclass \\w+[:(]"

# =====================================================================================
# TAG RULES — per-tag priority, TTL, and custom summarization prompts
# =====================================================================================
# match: fnmatch pattern against tag names
# priority: 1-10 scale, higher = assembled first when budget is tight
# ttl_days: auto-delete stored segments after N days (null = never expire)
# summary_prompt: custom LLM prompt for summarizing this tag's segments

tag_rules:
  - match: "architecture*"
    priority: 10
    ttl_days: null
    summary_prompt: |
      Summarize architectural decisions, design patterns, and tradeoffs.
      Preserve ADR numbers, component names, and rationale.

  - match: "database*"
    priority: 8
    ttl_days: null

  - match: "debug*"
    priority: 7
    ttl_days: 7

  - match: "legal*"
    priority: 9
    ttl_days: null
    summary_prompt: |
      Summarize legal discussion. Preserve case names, filing deadlines,
      court orders, legal strategies, and opposing counsel positions.

  - match: "medical*"
    priority: 8
    ttl_days: 90

  - match: "*"
    priority: 5
    ttl_days: 30

# =====================================================================================
# COMPACTION — when and how old conversation turns are compressed
# =====================================================================================
# When token usage crosses a threshold (fraction of context_window), old turns are
# grouped by tag and summarized. The raw turns are replaced by compact summaries,
# freeing space while preserving the information in the store.

compaction:
  # soft_threshold: Fraction of context_window that triggers proactive compaction.
  # Runs in a background thread — non-blocking. At 0.70 with a 120k window,
  # compaction fires when usage crosses ~84k tokens.
  soft_threshold: 0.70

  # hard_threshold: Fraction that triggers mandatory blocking compaction.
  # The engine will NOT proceed until compaction frees enough space.
  # At 0.85 with a 120k window, this fires at ~102k tokens.
  hard_threshold: 0.85

  protected_recent_turns: 6                         # recent turn pairs never compacted
  overflow_buffer: 1.2                              # compact 20% more than needed to reduce frequency
  summary_ratio: 0.15                               # target summary/original ratio (0.15 = ~85% compression)
  min_summary_tokens: 200                           # floor on individual segment summary length
  max_summary_tokens: 2000                          # ceiling on individual segment summary length
  max_concurrent_summaries: 4                       # parallel summarization calls via ThreadPoolExecutor
  llm_token_overhead: 2000                          # extra tokens reserved for LLM reasoning overhead

# =====================================================================================
# SEGMENTER
# =====================================================================================

segmenter:
  session_gap_minutes: 30                           # split segments when messages >N min apart (0=disabled)

# =====================================================================================
# SUMMARIZATION — LLM used for compaction summaries
# =====================================================================================

summarization:
  provider: "ollama"                                # must match a key in providers section
  model: "qwen3:4b-instruct-2507-fp16"
  max_tokens: 1000
  temperature: 0.3

# =====================================================================================
# PROVIDERS — LLM endpoint configurations
# =====================================================================================
# Supported types:
#   "generic_openai" — any OpenAI-compatible API (Ollama, LM Studio, vLLM, etc.)
#   "openrouter"     — OpenRouter (auto-injects HTTP-Referer header)
#   "anthropic"      — Anthropic API (Claude models)

providers:
  ollama:
    type: "generic_openai"
    base_url: "http://127.0.0.1:11434/v1"

  # openrouter:
  #   type: "openrouter"
  #   base_url: "https://openrouter.ai/api/v1"
  #   api_key_env: "OPENROUTER_API_KEY"

  # anthropic:
  #   type: "anthropic"
  #   api_key_env: "ANTHROPIC_API_KEY"

# =====================================================================================
# STORAGE
# =====================================================================================

storage:
  backend: "sqlite"                                 # "sqlite" | "filesystem" | "postgres" | "neo4j" | "falkordb"
  sqlite:
    path: ".virtualcontext/store.db"
  filesystem:
    root: ".virtualcontext/store"
  # postgres:
  #   dsn: ""
  # neo4j:
  #   uri: ""
  #   user: "neo4j"
  #   password: ""
  # falkordb:
  #   host: "localhost"
  #   port: 6379
  #   password: ""

# =====================================================================================
# SEARCH — find_quote excerpt and snippet lengths
# =====================================================================================

search:
  # Excerpt/snippet lengths
  excerpt_context_chars: 200              # chars of context around a LIKE/manual match
  fts_snippet_chars: 500                  # FTS5 snippet max chars for segment search
  tool_output_snippet_chars: 100          # FTS5 snippet max chars for tool output search
  postgres_max_words: 100                 # ts_headline MaxWords for Postgres FTS
  # Result limits
  find_quote_max_results: 20              # max results from vc_find_quote tool calls
  find_quote_default_results: 5           # default max_results for engine.find_quote()
  remember_when_max_results: 5            # default max_results for vc_remember_when
  semantic_search_max_results: 5          # max results from embedding-based search
  query_facts_default_limit: 50           # default limit for query_facts()

# =====================================================================================
# FACTS — fact extraction and graph linking
# =====================================================================================

facts:
  graph_links: true                                 # enable fact-to-fact relationship graph
  link_types:
    - supersedes
    - caused_by
    - part_of
    - contradicts
    - same_as
    - related_to

# =====================================================================================
# SUPERSESSION — fact supersession checking at compaction time
# =====================================================================================

supersession:
  enabled: false
  provider: ""                                      # empty = use summarization provider
  model: ""                                         # empty = use summarization model
  batch_size: 20

# =====================================================================================
# CURATION — LLM-based fact curation
# =====================================================================================

curation:
  enabled: false
  provider: ""
  model: ""
  max_response_tokens: 2048

# =====================================================================================
# TOOL OUTPUT INTERCEPTION — truncate large tool results, index for search
# =====================================================================================

tool_output:
  enabled: false
  default_truncate_threshold: 8192                  # truncate results larger than 8KB
  max_index_bytes: 524288                           # 512KB max indexed per tool result
  default_head_ratio: 0.6
  default_tail_ratio: 0.4
  # rules:                                          # per-tool overrides
  #   - match: "read_file"
  #     truncate_threshold: 16384

# =====================================================================================
# PROXY — HTTP proxy settings
# =====================================================================================

proxy:
  request_log_dir: ".virtualcontext/request_log"
  request_log_max_files: 50
  upstream_context_limit: 200000                    # max tokens the upstream model accepts
  # instances:                                      # multi-instance proxy config
  #   - port: 5757
  #     upstream: "https://api.anthropic.com"
  #     label: "anthropic"
  #     host: "127.0.0.1"

# =====================================================================================
# ASSEMBLY — how retrieved context is built for the LLM
# =====================================================================================

assembly:
  core_context_max_tokens: 18000                    # budget for always-included files
  tag_context_max_tokens: 30000                     # budget for retrieved tag summaries
  facts_max_tokens: 20000                           # budget for facts block
  recent_turns_always_included: 3                   # recent turns always in assembled context
  context_hint_enabled: true
  context_hint_max_tokens: 2000
  core_files: []
  # core_files:
  #   - path: "SOUL.md"
  #     priority: 10

# =====================================================================================
# RETRIEVAL — tag-overlap based context retrieval
# =====================================================================================

retrieval:
  skip_active_tags: true
  active_tag_lookback: 4
  anchorless_lookback: 6                            # recent turns for working set
  inbound_tagger_type: "embedding"                  # "embedding" or "llm"
  embedding_model: "all-MiniLM-L6-v2"
  embedding_threshold: 0.3
  strategy_config:
    default:
      min_overlap: 1
      max_results: 10
      max_budget_fraction: 0.25
      include_related: true

# =====================================================================================
# TELEMETRY — cost tracking and performance monitoring
# =====================================================================================
# Pricing is managed by models.yaml (see telemetry.models_file).

telemetry:
  enabled: false
  models_file: "models.yaml"
